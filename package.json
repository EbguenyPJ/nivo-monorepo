{
  "name": "nivo-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "turbo run db:migrate --filter=@nivo/api",
    "db:seed": "turbo run db:seed --filter=@nivo/api",
    "db:simulate-master": "turbo run db:simulate-master --filter=@nivo/api"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "msgpackr-extract",
      "@nestjs/core"
    ]
  },
  "dependencies": {
    "typeorm": "^0.3.28"
  }
}
