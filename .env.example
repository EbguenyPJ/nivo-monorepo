# ==========================================
# Nivo SaaS - Environment Variables
# ==========================================

# Database (Master)
MASTER_DB_HOST=localhost
MASTER_DB_PORT=5432
MASTER_DB_USERNAME=nivo_admin
MASTER_DB_PASSWORD=nivo_secret_2024
MASTER_DB_NAME=nivo_master_db

# Database (Tenant - default connection params)
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USERNAME=nivo_admin
TENANT_DB_PASSWORD=nivo_secret_2024

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (Test Mode)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Storage (S3/R2) - Mock for now
STORAGE_PROVIDER=local
S3_BUCKET=nivo-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# ── Report Export Engine ──────────────────────────────────────────────────────
# S3 bucket for temp report files (must have a 24h lifecycle rule on /temp-reports/ prefix)
# Leave S3_BUCKET blank to use local disk fallback (./uploads/reports/) in development
REPORTS_S3_BUCKET=nivo-reports
REPORTS_S3_REGION=us-east-1
REPORTS_S3_ACCESS_KEY=your_access_key
REPORTS_S3_SECRET_KEY=your_secret_key

# Resend — transactional email for report distribution
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=reportes@nivo.com

# WhatsApp Business — Meta Cloud API for report distribution
# Set up at https://developers.facebook.com/apps/ → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# Puppeteer / Chromium — path to system Chrome/Chromium for PDF generation
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome   or   /usr/bin/chromium-browser
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Leave blank to let puppeteer-core auto-detect (works in most CI environments)
CHROMIUM_PATH=

# Frontend base URL — used by the PDF worker to navigate to print pages
# Must be reachable from the API process (e.g. localhost in dev, real domain in prod)
FRONTEND_URL=http://localhost:3001

# App URLs
API_URL=http://localhost:3000
POS_ADMIN_URL=http://localhost:3001
STOREFRONT_URL=http://localhost:3002

# App Config
NODE_ENV=development
PORT=3000

# ── PAC (Proveedor Autorizado de Certificación) ──────────────────────────────
# Recommended: Facturama (apisandbox.facturama.mx for testing)
PAC_API_URL=https://apisandbox.facturama.mx
PAC_USERNAME=your_facturama_username
PAC_PASSWORD=your_facturama_password

# Emisor data (your own RFC, legal name, regime, and fiscal zip code as platform owner)
PAC_EMISOR_RFC=YOUR_RFC_HERE
PAC_EMISOR_NOMBRE=YOUR_LEGAL_NAME_HERE
PAC_EMISOR_REGIMEN=601
PAC_EMISOR_CP=06600

# ── Email Notifications (SendGrid — invoice error/ready emails) ───────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SUPPORT_EMAIL=soporte@nivo.com

# ── Email Config (Demo) ──────────────────────────────────────────────────────
# Used by @nestjs-modules/mailer, billing-tasks worker, and mobile notifications
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=nivo.demo2@gmail.com
MAIL_PASS=NiVo241195!
MAIL_FROM="Nivo Demo <nivo.demo2@gmail.com>"

# SMTP aliases (legacy — fallback when MAIL_* not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=nivo.demo2@gmail.com
SMTP_USER=nivo.demo2@gmail.com
SMTP_PASS=NiVo241195!

# ── WhatsApp Business — Meta Cloud API ────────────────────────────────────────
# Set up at https://developers.facebook.com/apps/ → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_RECIPIENT_NUMBER=+522228124824

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Reports Engine (Puppeteer + S3) ──────────────────────────────────────────
REPORTS_S3_BUCKET=nivo-reports
REPORTS_S3_REGION=us-east-1
REPORTS_S3_ACCESS_KEY=your_access_key
REPORTS_S3_SECRET_KEY=your_secret_key
